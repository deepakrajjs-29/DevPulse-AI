# DevPulse AI - Environment Configuration Template

# GitHub Personal Access Token (PAT)
# Required for authenticated API access (5,000 req/hr rate limit).
# Leave empty for unauthenticated access (60 req/hr rate limit).
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub Username to inspect
GITHUB_USERNAME=octocat

# Optional log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
